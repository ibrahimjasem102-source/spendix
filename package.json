{
  "name": "spendix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run build",
    "lint": "next lint",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "android:dev": "set CAPACITOR_URL=http://10.0.2.2:3001 && npx cap sync android && npx cap open android",
    "android:prod": "npx cap sync android && npx cap open android",
    "android:apk": "npm run build && npx cap sync android && android\\gradlew.bat -p android assembleDebug",
    "android:install": "npm run build && npx cap sync android && android\\gradlew.bat -p android assembleDebug && adb install -r android\\app\\build\\outputs\\apk\\debug\\app-debug.apk"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.55.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-virtual": "^3.13.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.39.0",
    "lucide-react": "^0.511.0",
    "next": "^15.3.9",
    "next-pwa": "^5.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.3",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "eslint": "^9",
    "eslint-config-next": "15.3.2",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
